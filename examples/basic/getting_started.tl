// Getting Started with .tl Language
// This is the simplest possible example to get you started

// Every .tl program needs a main function
func main() -> int {
    // Print a simple message
    print("Hello from .tl language!");
    
    // Declare a variable
    let number: int = 42;
    print(number);
    
    // Simple arithmetic
    let result: int = 10 + 5;
    print(result);
    
    // Return 0 to indicate success
    return 0;
}
